DISCORD_TOKEN="Discord Token is written in my real .env file"
DEEPSEEK_API_KEY="DeepSeek API key"
CHANNEL_ID="Discord channel ID where the bot will send messages"

# 선택 — Discord Webhook 전송 (USE_DISCORD_WEBHOOK=1 필요)
# DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."
# USE_DISCORD_WEBHOOK="1"

# 선택 — 테스트 채널로 전송
# TEST_CHANNEL_ID="123456789"
# USE_TEST_CHANNEL="1"

# 선택 — dry-run (Discord 전송 없음)
# DRY_RUN="1"
# DRY_RUN_OUTPUT_PATH="data/dry_run_briefing.json"

# 선택 — RSS·수집·전송 설정
# RSS_URLS="https://example.com/feed.xml,https://example.com/feed2.xml"
# TIER_1_SOURCES="Fabrizio Romano,David Ornstein"
# MAX_ARTICLES_PER_SOURCE="5"
# RSS_FETCH_TIMEOUT="10"
# DEEPSEEK_MODEL="deepseek-chat"
# SENT_URLS_PATH="data/sent_urls.json"
# SENT_URL_RETENTION_DAYS="7"
# MAX_EMBEDS_PER_RUN="15"
# EMBED_SEND_DELAY_SEC="0.6"
# EMBED_LAYOUT="individual"
# MAX_RAW_NEWS_CHARS="12000"
# MAX_NEWS_BLOCKS_FOR_AI="20"
# TIER1_ONLY="1"
# FAILURE_WEBHOOK_URL="https://discord.com/api/webhooks/..."
